# Example Nginx reverse proxy for دیار on VPS
# Copy to /etc/nginx/sites-available/diar and symlink to sites-enabled.

server {
    listen 80;
    server_name diar.example.com;

    # Redirect HTTP to HTTPS (uncomment when TLS is configured)
    # return 301 https://$host$request_uri;
}

