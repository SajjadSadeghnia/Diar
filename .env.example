# =============================================================================
# دیار — environment template (copy to .env on server; never commit .env)
# =============================================================================

# PostgreSQL (production: use VPS localhost + dedicated user)
DATABASE_URL="postgresql://diar:CHANGE_ME@localhost:5432/property_agah"

# Required in production — generate: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# production on VPS | development locally
NODE_ENV="production"

# App port (PM2 / next start)
PORT=3000

# Optional: public HTTPS URL (cookies / redirects behind Nginx)
# APP_URL="https://diar.yourdomain.com"

# Admin Telegram bot (Phase 2) — token only in env; chat IDs in TelegramRecipient table
# TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"

# -----------------------------------------------------------------------------
# Production bootstrap (scripts/production-bootstrap.ts) — run ONCE on fresh DB
# -----------------------------------------------------------------------------
ADMIN_PHONE="09121234567"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
ADMIN_NAME="ادمین دیار"

# Optional property / payment defaults for bootstrap
# PROPERTY_CONTACT_PHONE="021-88776655"
# PROPERTY_DAILY_PRICE=3500000
# PAYMENT_CARD_NUMBER="6037-9975-0000-0000"
# PAYMENT_INSTRUCTIONS="پس از واریز، تصویر رسید را بارگذاری کنید."
